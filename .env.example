# Supabase Configuration
# Get your project URL and anon key from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Alpha Vantage API Key (free tier, 25 requests/day)
# Get your free key at: https://www.alphavantage.co/support/#api-key
VITE_ALPHA_VANTAGE_KEY=your_api_key_here

# Financial Modeling Prep API Key
# Get your free key at: https://financialmodelingprep.com/developer
VITE_FMP_API_KEY=your_fmp_api_key_here

# Google Gemini AI API Key
# Get your free key at: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
